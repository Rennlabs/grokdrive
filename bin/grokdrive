#!/usr/bin/env bash
# grokdrive — session-scoped "burn Grok credit" mode.
#
# Routes all EXECUTION and heavy SUB-AGENT work to Grok 4.5 (Grok Build CLI,
# headless), while the Claude session model (Opus / Fable) stays the
# ADVISOR-ORCHESTRATOR: it plans, routes, reviews, and verifies — but does not
# touch the keyboard directly. A companion PreToolUse hook (grokdrive-gate.js)
# hard-blocks direct Claude Write/Edit while this mode is active for the session.
#
#   grokdrive on   [--effort auto|high|medium|low] [--advisor opus|fable] [--global]
#   grokdrive off  [--global]
#   grokdrive status
#   grokdrive "<task spec>"            # dispatch one body to Grok (bare form)
#   grokdrive run  "<spec>" | -f FILE # same, explicit; stdin also accepted
#   grokdrive parallel "A" "B" "C"    # fan out independent bodies, collect
#   grokdrive verify --gate "<cmd>" [--loop <mode>]   # external gate -> verdict marker
#   grokdrive doctor                  # grok on PATH, state writable, hook installed
#
# Effort: the user asked for "Grok 4.5 high and medium" — `auto` (default) picks
#   HIGH for large/complex specs and MEDIUM for standard ones; never LOW unless asked.
# Env: GROKDRIVE_EFFORT, GROKDRIVE_MODEL (empty = grok default 4.5), GROKDRIVE_MAX_TURNS,
#   GROKDRIVE_TIMEOUT, GROKDRIVE_SANDBOX, GROKDRIVE_STATE_DIR, GROKDRIVE_SESSION.
# Kill-switch for the gate: CLAUDE_GUARDS_OFF=1  (or just `grokdrive off`).
set -uo pipefail

STATE_DIR="${GROKDRIVE_STATE_DIR:-$HOME/.claude/.grokdrive-state}"
SESSION="${GROKDRIVE_SESSION:-${CLAUDE_CODE_SESSION_ID:-${CLAUDE_SESSION_ID:-global}}}"
mkdir -p "$STATE_DIR" 2>/dev/null || true

DEFAULT_EFFORT="${GROKDRIVE_EFFORT:-auto}"
MAX_TURNS="${GROKDRIVE_MAX_TURNS:-60}"
MODEL="${GROKDRIVE_MODEL:-}"
SANDBOX="${GROKDRIVE_SANDBOX:-}"
TIMEOUT="${GROKDRIVE_TIMEOUT:-1200}"
HOOK_FILE="$HOME/.claude/hooks/grokdrive-gate.js"

_now() { date -u +%Y-%m-%dT%H:%M:%SZ; }
_stamp() { date -u +%Y%m%dT%H%M%SZ; }
_have() { command -v "$1" >/dev/null 2>&1; }
_die() { echo "grokdrive: $*" >&2; exit 2; }

# state file for a scope: session (default) or global (all.json = every session)
_sfile() { if [[ "${1:-}" == "global" ]]; then echo "$STATE_DIR/all.json"; else echo "$STATE_DIR/$SESSION.json"; fi; }

_read_json_field() { # <file> <key>
  python3 - "$1" "$2" 2>/dev/null <<'PY'
import json,sys
try:
    d=json.load(open(sys.argv[1]))
    v=d.get(sys.argv[2],"")
    print(v if v is not None else "")
except Exception:
    print("")
PY
}

_active_state() { # echo path of an active state file for this session, if any
  for f in "$STATE_DIR/$SESSION.json" "$STATE_DIR/all.json"; do
    [[ -f "$f" ]] || continue
    [[ "$(_read_json_field "$f" active)" == "True" || "$(_read_json_field "$f" active)" == "true" ]] && { echo "$f"; return 0; }
  done
  return 1
}

# ---- prompt reading (args | -f FILE | stdin; arg+stdin => arg is instruction) ----
_read_prompt() {
  if [[ "${1:-}" == "-f" ]]; then
    [[ -n "${2:-}" && -r "$2" ]] || _die "cannot read -f file: ${2:-<none>}"
    cat "$2"; return
  fi
  local args="" piped=""
  [[ $# -gt 0 && "$*" != "-" ]] && args="$*"
  [[ ! -t 0 ]] && piped="$(cat)"
  if [[ -n "$args" && -n "$piped" ]]; then printf '%s\n\n%s' "$args" "$piped"
  elif [[ -n "$args" ]]; then printf '%s' "$args"
  else printf '%s' "$piped"; fi
}

_effort_for() { # <spec>
  local e="$DEFAULT_EFFORT" spec="$1"
  if [[ "$e" != "auto" ]]; then echo "$e"; return; fi
  local n=${#spec}
  if (( n > 700 )) || echo "$spec" | grep -qiE 'refactor|architect|design|migrat|debug|investigat|multi-file|across the|end-to-end|security|concurren|redesign|rewrite|root cause|race condition'; then
    echo high
  else
    echo medium
  fi
}

_artifact_dir() {
  local d
  if d="$PWD/.omc/artifacts/grokdrive"; mkdir -p "$d" 2>/dev/null; then echo "$d"; return; fi
  d="$STATE_DIR/artifacts"; mkdir -p "$d" 2>/dev/null; echo "$d"
}

_bump_dispatch() { # increment dispatch counter on the active state file
  local f; f="$(_active_state)" || return 0
  python3 - "$f" 2>/dev/null <<'PY' || true
import json,sys
f=sys.argv[1]
try:
    d=json.load(open(f))
except Exception:
    d={}
d["dispatches"]=int(d.get("dispatches",0))+1
json.dump(d,open(f,"w"),indent=1)
PY
}

# ---------------------------------------------------------------- dispatch core
_dispatch() { # <effort> <label>  (prompt via $PROMPT text or $PROMPT_FILE)
  local effort="$1" label="$2"
  _have grok || _die "grok (Grok Build CLI) not on PATH"
  local args=(--output-format plain --always-approve --max-turns "$MAX_TURNS" --effort "$effort")
  [[ -n "$MODEL" ]] && args+=(-m "$MODEL")
  [[ -n "$SANDBOX" ]] && args+=(--sandbox "$SANDBOX")
  if [[ -n "${PROMPT_FILE:-}" ]]; then args+=(--prompt-file "$PROMPT_FILE"); else args+=(-p "$PROMPT"); fi

  local adir art err rc
  adir="$(_artifact_dir)"; art="$adir/$(_stamp)-${label}.md"; err="$(mktemp)"
  {
    echo "# grokdrive dispatch — $(_now)"
    echo "effort=$effort model=${MODEL:-<grok-default>} max_turns=$MAX_TURNS cwd=$PWD"
    echo "---"
  } >"$art"
  # run grok; tee stdout into the artifact
  if timeout "$TIMEOUT" grok "${args[@]}" </dev/null 2>"$err" | tee -a "$art"; then rc=0; else rc=${PIPESTATUS[0]}; fi
  if [[ $rc -eq 124 || $rc -eq 137 ]]; then
    echo "[grokdrive: grok timed out after ${TIMEOUT}s — narrow the spec or raise GROKDRIVE_TIMEOUT]" >&2
  elif [[ $rc -ne 0 ]]; then
    echo "[grokdrive: grok exit $rc — stderr tail:]" >&2
    grep -vE 'MaxFilesWatch|failed to watch root recursively' "$err" 2>/dev/null | tail -5 >&2
  fi
  rm -f "$err"
  echo "[artifact: $art]" >&2
  _bump_dispatch
  return $rc
}

# ------------------------------------------------------------------- subcommands
cmd_on() {
  local scope="session" effort="$DEFAULT_EFFORT" advisor="opus"
  while [[ $# -gt 0 ]]; do case "$1" in
    --effort) effort="${2:-auto}"; shift 2;;
    --advisor) advisor="${2:-opus}"; shift 2;;
    --global) scope="global"; shift;;
    *) shift;;
  esac; done
  local f; f="$(_sfile "$scope")"
  cat >"$f" <<JSON
{
 "active": true,
 "session": "$SESSION",
 "scope": "$scope",
 "effort": "$effort",
 "advisor": "$advisor",
 "since": "$(_now)",
 "dispatches": 0
}
JSON
  echo "grokdrive: ON ($scope) — advisor=$advisor, effort=$effort"
  echo "  Execution + heavy sub-agents now route to Grok 4.5. Claude ($advisor) is advisor/orchestrator."
  echo "  Direct Claude Write/Edit is hard-gated (trivial <=${GROKDRIVE_TRIVIAL_LINES:-20}-line edits still pass)."
  [[ -f "$HOOK_FILE" ]] || echo "  ⚠ gate hook missing: $HOOK_FILE (run: grokdrive doctor)"
}

cmd_off() {
  local sf gf removed=0
  sf="$STATE_DIR/$SESSION.json"; gf="$STATE_DIR/all.json"
  if [[ "${1:-}" == "--global" ]]; then
    [[ -f "$gf" ]] && { rm -f "$gf"; removed=1; }
    [[ -f "$sf" ]] && { rm -f "$sf"; removed=1; }
    [[ $removed -eq 1 ]] && echo "grokdrive: OFF (global + session) — gate disarmed everywhere." || echo "grokdrive: already off."
    return
  fi
  [[ -f "$sf" ]] && { rm -f "$sf"; removed=1; }
  if [[ -f "$gf" ]] && grep -q '"active": true' "$gf" 2>/dev/null; then
    echo "grokdrive: session gate cleared, but a GLOBAL gate (all.json) is still active for ALL sessions."
    echo "  Run 'grokdrive off --global' to disarm it, or CLAUDE_GUARDS_OFF=1 to bypass."
    return
  fi
  [[ $removed -eq 1 ]] && echo "grokdrive: OFF — direct Claude execution restored." || echo "grokdrive: already off (session=$SESSION)."
}

cmd_status() {
  local f; if f="$(_active_state)"; then
    echo "grokdrive: ACTIVE"; cat "$f"
  else
    echo "grokdrive: inactive (session=$SESSION)"
  fi
}

cmd_run() {
  PROMPT_FILE=""; PROMPT=""
  if [[ "${1:-}" == "-f" ]]; then
    [[ -n "${2:-}" && -r "$2" ]] || _die "cannot read -f file: ${2:-<none>}"
    PROMPT_FILE="$2"; PROMPT="$(cat "$2")"
  else
    PROMPT="$(_read_prompt "$@")"
  fi
  [[ -n "${PROMPT//[$' \t\n']/}" || -n "$PROMPT_FILE" ]] || _die "empty spec"
  local effort; effort="$(_effort_for "$PROMPT")"
  echo "── grokdrive → Grok 4.5 (effort=$effort) ─────────────────────────────" >&2
  _dispatch "$effort" "body"
}

cmd_parallel() {
  [[ $# -ge 1 ]] || _die "parallel needs >=1 spec"
  _have grok || _die "grok not on PATH"
  local pids=() outs=() i=0 adir; adir="$(_artifact_dir)"
  for spec in "$@"; do
    local eff out; eff="$(_effort_for "$spec")"; out="$adir/$(_stamp)-par$i.md"
    ( PROMPT="$spec"; PROMPT_FILE=""
      { echo "# grokdrive parallel #$i (effort=$eff) — $(_now)"; echo "spec: $spec"; echo "---"; } >"$out"
      timeout "$TIMEOUT" grok --output-format plain --always-approve --max-turns "$MAX_TURNS" --effort "$eff" \
        ${MODEL:+-m "$MODEL"} -p "$spec" </dev/null 2>/dev/null | tee -a "$out" >/dev/null
    ) & pids+=($!); outs+=("$out"); i=$((i+1))
  done
  local j=0
  for pid in "${pids[@]}"; do wait "$pid"; _bump_dispatch; j=$((j+1)); done
  for out in "${outs[@]}"; do echo "===== ${out##*/} ====="; cat "$out"; echo; done
}

cmd_verify() {
  local gate="" loop=""
  while [[ $# -gt 0 ]]; do case "$1" in
    --gate) gate="${2:-}"; shift 2;;
    --loop) loop="${2:-}"; shift 2;;
    *) shift;;
  esac; done
  [[ -n "$gate" ]] || _die "verify needs --gate \"<command>\""
  echo "── grokdrive verify — gate: $gate ───────────────────────────────" >&2
  local rc result sha paths sdir
  set +e; bash -c "$gate"; rc=$?      # script runs -uo pipefail (never -e); keep +e so a
                                       # failing gate/pipeline can't abort before the marker writes
  [[ $rc -eq 0 ]] && result="GREEN" || result="RED"
  sha="$(git diff 2>/dev/null | sha256sum 2>/dev/null | cut -c1-16)"; [[ -n "$sha" ]] || sha="n/a"
  paths="$(git diff --name-only 2>/dev/null | head -40 | paste -sd, - 2>/dev/null)"
  sdir="$PWD/.omc/state"; mkdir -p "$sdir" 2>/dev/null || sdir="$STATE_DIR"
  GD_RESULT="$result" GD_GATE="$gate" GD_TS="$(_now)" GD_SHA="$sha" GD_PATHS="${paths:-}" \
  GD_SDIR="$sdir" GD_LOOP="$loop" python3 - <<'PY'
import json,os
body={"result":os.environ["GD_RESULT"],"gate":os.environ["GD_GATE"],
      "ts":os.environ["GD_TS"],"diff_sha":os.environ["GD_SHA"],"paths":os.environ["GD_PATHS"]}
sdir=os.environ["GD_SDIR"]
open(os.path.join(sdir,"grokdrive-verifier.json"),"w").write(json.dumps(body,indent=1)+"\n")
loop=os.environ.get("GD_LOOP","")
if loop:
    open(os.path.join(sdir,loop+"-verifier.json"),"w").write(json.dumps(body,indent=1)+"\n")
PY
  echo "grokdrive verify: $result (gate exit $rc) -> $sdir/grokdrive-verifier.json"
  [[ "$result" == "GREEN" ]]
}

cmd_doctor() {
  local ok=1
  printf '%-28s' "grok (Grok Build CLI):"; if _have grok; then echo "OK ($(command -v grok))"; else echo "MISSING"; ok=0; fi
  printf '%-28s' "state dir writable:"; if touch "$STATE_DIR/.w" 2>/dev/null && rm -f "$STATE_DIR/.w"; then echo "OK ($STATE_DIR)"; else echo "FAIL"; ok=0; fi
  printf '%-28s' "gate hook file:"; if [[ -f "$HOOK_FILE" ]]; then echo "OK"; else echo "MISSING ($HOOK_FILE)"; ok=0; fi
  printf '%-28s' "gate hook registered:"; if grep -q "grokdrive-gate.js" "$HOME/.claude/settings.json" 2>/dev/null; then echo "OK (settings.json PreToolUse)"; else echo "NOT REGISTERED"; ok=0; fi
  printf '%-28s' "session id:"; echo "$SESSION"
  printf '%-28s' "effort default:"; echo "$DEFAULT_EFFORT (auto => high|medium)"
  [[ $ok -eq 1 ]] && { echo "doctor: PASS"; return 0; } || { echo "doctor: FAIL"; return 1; }
}

# ------------------------------------------------------------------------- main
main() {
  local sub="${1:-}"
  case "$sub" in
    on)       shift; cmd_on "$@";;
    off)      shift; cmd_off "$@";;
    status|st) cmd_status;;
    run)      shift; cmd_run "$@";;
    parallel|par) shift; cmd_parallel "$@";;
    verify)   shift; cmd_verify "$@";;
    doctor|dr) cmd_doctor;;
    ""|-h|--help|help)
      sed -n '2,32p' "$0" | sed 's/^# \{0,1\}//';;
    *)        cmd_run "$@";;   # bare: treat all args as a run spec
  esac
}
main "$@"
